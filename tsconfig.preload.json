{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir": "dist/preload",
    "rootDir": "src/preload",
    "types": ["node"],
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/preload"]
}
