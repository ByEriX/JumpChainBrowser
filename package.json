{
  "name": "jumpchain-browser",
  "version": "1.0.0",
  "description": "Desktop application for browsing JumpChain PDFs from community Google Drives",
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:main\" \"npm run dev:preload\" \"npm run dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:preload": "tsc -p tsconfig.preload.json --watch",
    "dev:renderer": "vite",
    "dev:electron": "node scripts/wait-for-vite.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer && npm run copy:assets && npm run build:oauth-config",
    "copy:assets": "node -e \"const fs=require('fs');const p=require('path');fs.mkdirSync(p.join('dist','main','db'),{recursive:true});fs.copyFileSync(p.join('src','main','db','schema.sql'),p.join('dist','main','db','schema.sql'));\"",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "build:oauth-config": "node scripts/generate-oauth-config.js",
    "start": "electron .",
    "dist": "npm run build && electron-builder",
    "postinstall": "npx @electron/rebuild",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.jumpchain.browser",
    "productName": "JumpChain Browser",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.entertainment"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.7",
    "electron-store": "^10.0.0",
    "googleapis": "^144.0.0",
    "lucide-react": "^0.468.0",
    "pdfjs-dist": "^4.8.69",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^40.9.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.4"
  },
  "author": "ByEriX",
  "license": "MIT"
}
